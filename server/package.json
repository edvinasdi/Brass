{
  "name": "brass-money-server",
  "version": "1.0.0",
  "description": "Socket.IO server for Brass: Birmingham Money Tracker",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "debug": "tsx watch --inspect src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "reset": "rm -f state/game.json && echo '✓ Game state cleared'",
    "set-admin": "tsx scripts/set-admin.ts"
  },
  "keywords": ["brass", "money", "tracker"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  }
}
